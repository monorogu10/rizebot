#!/usr/bin/env bash
set -Eeuo pipefail

APP_DIR="${RIZEBOT_DIR:-/opt/rizebot}"
PM2_APP="${RIZEBOT_PM2_APP:-rizebot}"
LOG_LINES="${RIZEBOT_LOG_LINES:-80}"

log() {
  printf '\n[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*"
}

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf 'Missing command: %s\n' "$1" >&2
    exit 1
  fi
}

require_command git
require_command node
require_command npm
require_command pm2

if [ ! -d "$APP_DIR" ]; then
  printf 'Rizebot directory not found: %s\n' "$APP_DIR" >&2
  printf 'Set a custom path with: RIZEBOT_DIR=/path/to/rizebot rizebot-update\n' >&2
  exit 1
fi

cd "$APP_DIR"

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  printf 'Not a git repository: %s\n' "$APP_DIR" >&2
  exit 1
fi

if ! git diff --quiet || ! git diff --cached --quiet; then
  printf 'Local tracked changes detected. Commit, stash, or reset them before update.\n' >&2
  git status --short
  exit 1
fi

before_sha="$(git rev-parse --short HEAD)"

log "Pulling latest code in $APP_DIR"
git pull --ff-only

after_sha="$(git rev-parse --short HEAD)"
if [ "$before_sha" = "$after_sha" ]; then
  log "Code already up to date at $after_sha"
else
  log "Updated $before_sha -> $after_sha"
fi

log "Installing production dependencies"
if [ -f package-lock.json ]; then
  npm ci --omit=dev --no-audit --no-fund
else
  npm install --omit=dev --no-audit --no-fund
fi

log "Checking JavaScript syntax"
node --check index.js
if [ -d src ]; then
  find src -name '*.js' -print0 | xargs -0 -n1 node --check
fi

if ! pm2 describe "$PM2_APP" >/dev/null 2>&1; then
  printf 'PM2 app not found: %s\n' "$PM2_APP" >&2
  pm2 list
  printf 'Set a custom PM2 app name with: RIZEBOT_PM2_APP=name rizebot-update\n' >&2
  exit 1
fi

log "Restarting PM2 app: $PM2_APP"
pm2 restart "$PM2_APP" --update-env
pm2 save >/dev/null 2>&1 || true

log "Recent PM2 logs"
pm2 logs "$PM2_APP" --lines "$LOG_LINES" --nostream

log "Update complete"
